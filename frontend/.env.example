# Clerk Authentication (get these from https://clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Optional: Clerk URLs (defaults are usually fine)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# S3 / DigitalOcean Spaces credentials for presigned upload URLs.
# Both vars are REQUIRED — the /api/training/datasets/presigned route
# refuses to sign without them. Leave blank locally to fail fast.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET=aistudio-training-datasets
# Leave S3_ENDPOINT unset for AWS; set it for S3-compatible services
# (e.g. https://nyc3.digitaloceanspaces.com).
S3_ENDPOINT=

# ── Observability (T08) ────────────────────────────────────────────────
# All are optional — leave blank to disable the integration. The app
# runs as a no-op when keys are missing, so dev / previews don't have
# to provision anything.

# Sentry (error tracking + traces). Get the DSN from your Sentry project
# settings. NEXT_PUBLIC_SENTRY_DSN ships to the browser bundle; SENTRY_DSN
# stays server-only. SENTRY_AUTH_TOKEN is only used during `next build` to
# upload source maps and can be omitted in dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_RATE=0.05
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_RELEASE=

# PostHog (product analytics). The browser SDK reads NEXT_PUBLIC_* vars;
# server-side captures use POSTHOG_KEY.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Logging — `silent`, `error`, `warn`, `info`, `debug`, `trace`. Defaults
# to `info` in production and `debug` otherwise.
LOG_LEVEL=

# Shared-secret used to guard /api/metrics. Leave blank to expose the
# endpoint publicly (only do this if the route is behind a private network).
METRICS_TOKEN=
